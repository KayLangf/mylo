ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Shared password gating the web UI's API routes (chat/greeting/export) —
# required so the deployed URL can't be used by strangers to drain API
# tokens. Set a real value here for local web-UI testing, and set the
# same variable in the Vercel project's environment for the deployment.
# Unset = all web API requests are rejected (fails closed).
MYLO_ACCESS_PASSWORD=
